# ============================================
# MANGA/ANIME UPLOADER BOT — Configuration
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================

# ── Telegram Bot ──────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Canaux pour les annonces (séparés par virgule)
# Ex: @monchannel,-1001234567890
TELEGRAM_CHANNELS=

# ── Telegram MTProto (streaming vidéo via Telethon) ──
# Obtenez sur https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Session string Telethon (généré automatiquement à la 1ère connexion)
TELETHON_SESSION=

# ── Supabase ──────────────────────────────
SUPABASE_URL=https://xfwbqsyqanapbixlkesd.supabase.co
# Clé service_role (pas anon key) — bypasse le RLS
SUPABASE_SERVICE_KEY=

# ── Cloudflare R2 ─────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=live-chapter
# URL publique du bucket R2
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ── API Streaming ─────────────────────────
# Port du serveur FastAPI (défaut: 8000)
API_PORT=8000

# ── Metadata APIs (optionnel) ─────────────
# TMDB: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Limites ───────────────────────────────
MAX_FILE_SIZE_MB=500
